# OmniWatch 2.0 — Environment Variables
# Copy this file to .env and fill in your values

# ─── Kafka ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TELEMETRY_RAW=omniwatch.telemetry.raw
KAFKA_TOPIC_METRICS_RAW=omniwatch.metrics.raw
KAFKA_TOPIC_LOGS_RAW=omniwatch.logs.raw
KAFKA_TOPIC_TRACES_RAW=omniwatch.traces.raw
KAFKA_TOPIC_TOPOLOGY_DELTAS=omniwatch.topology.deltas
KAFKA_TOPIC_ANOMALIES_DETECTED=omniwatch.anomalies.detected
KAFKA_TOPIC_INCIDENTS_CREATED=omniwatch.incidents.created
KAFKA_TOPIC_REMEDIATION_ACTIONS=omniwatch.remediation.actions
KAFKA_TOPIC_SECURITY_EVENTS=omniwatch.security.events
KAFKA_TOPIC_CONFIG_DRIFT=omniwatch.config.drift
KAFKA_TOPIC_SIMULATION_RESULTS=omniwatch.simulation.results

# ─── ClickHouse ─────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=omniwatch

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── MinIO / Object Storage ────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_TELEMETRY=omniwatch-telemetry-archive
MINIO_BUCKET_INCIDENTS=omniwatch-incidents
MINIO_BUCKET_AUDIT=omniwatch-audit-logs
MINIO_BUCKET_MLDATA=omniwatch-ml-datasets
MINIO_BUCKET_RUNBOOKS=omniwatch-runbooks
MINIO_BUCKET_COMPLIANCE=omniwatch-compliance
MINIO_BUCKET_SIMULATIONS=omniwatch-simulations

# ─── Apache Kuzu (Graph Database) ──────────────────────────────────
KUZU_DATABASE_PATH=/data/omniwatch-graph

# ─── OPA (Open Policy Agent) ───────────────────────────────────────
OPA_ENDPOINT=http://opa:8181

# ─── Ollama (LLM Inference) ───────────────────────────────────────
OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_MODEL=qwen2.5

# ─── Dashboard Backend ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_ENV=development
DASHBOARD_LOG_LEVEL=info

# ─── Dashboard Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ─── Security ──────────────────────────────────────────────────────
# Never commit real credentials. Use mock/simulate only.
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600
