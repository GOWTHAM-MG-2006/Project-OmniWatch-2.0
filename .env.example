# OmniWatch 2.0 — Environment Variables
# Copy this file to .env and fill in your values

# ─── Kafka ──────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_TELEMETRY_RAW=omniwatch.telemetry.raw
KAFKA_TOPIC_METRICS_RAW=omniwatch.metrics.raw
KAFKA_TOPIC_LOGS_RAW=omniwatch.logs.raw
KAFKA_TOPIC_TRACES_RAW=omniwatch.traces.raw
KAFKA_TOPIC_TOPOLOGY_DELTAS=omniwatch.topology.deltas
KAFKA_TOPIC_ANOMALIES_DETECTED=omniwatch.anomalies.detected
KAFKA_TOPIC_INCIDENTS_CREATED=omniwatch.incidents.created
KAFKA_TOPIC_REMEDIATION_ACTIONS=omniwatch.remediation.actions
KAFKA_TOPIC_SECURITY_EVENTS=omniwatch.security.events
KAFKA_TOPIC_CONFIG_DRIFT=omniwatch.config.drift
KAFKA_TOPIC_SIMULATION_RESULTS=omniwatch.simulation.results

# ─── ClickHouse ─────────────────────────────────────────────────────
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DATABASE=omniwatch

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ─── MinIO / Object Storage ────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_TELEMETRY=omniwatch-telemetry-archive
MINIO_BUCKET_INCIDENTS=omniwatch-incidents
MINIO_BUCKET_AUDIT=omniwatch-audit-logs
MINIO_BUCKET_MLDATA=omniwatch-ml-datasets
MINIO_BUCKET_RUNBOOKS=omniwatch-runbooks
MINIO_BUCKET_COMPLIANCE=omniwatch-compliance
MINIO_BUCKET_SIMULATIONS=omniwatch-simulations

# ─── Apache Kuzu (Graph Database) ──────────────────────────────────
KUZU_DATABASE_PATH=/data/omniwatch-graph

# ─── OPA (Open Policy Agent) ───────────────────────────────────────
OPA_ENDPOINT=http://opa:8181

# ─── Ollama (LLM Inference) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─── Dashboard Backend ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_ENV=development
DASHBOARD_LOG_LEVEL=info

# ─── Dashboard Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ─── Security ──────────────────────────────────────────────────────
# Never commit real credentials. Use mock/simulate only.

# JWT RS256 Keys (REQUIRED)
# Generate with: python -c "from cryptography.hazmat.primitives.asymmetric import rsa; from cryptography.hazmat.primitives import serialization; key = rsa.generate_private_key(public_exponent=65537, key_size=2048); print('JWT_PRIVATE_KEY=' + key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption()).decode()); print('JWT_PUBLIC_KEY=' + key.public_key().public_bytes(serialization.Encoding.PEM, serialization.PublicFormat.SubjectPublicKeyInfo).decode())"
JWT_PRIVATE_KEY=  # Required: RSA private key (PEM format)
JWT_PUBLIC_KEY=   # Required: RSA public key (PEM format)

# SSO Configuration (OIDC or SAML2 — at least one required)
# OIDC Configuration
OIDC_CLIENT_ID=  # Optional: OIDC client ID
OIDC_CLIENT_SECRET=  # Optional: OIDC client secret
OIDC_ISSUER=  # Optional: OIDC issuer URL

# SAML2 Configuration (fallback when OIDC not configured)
SAML_IDP_URL=  # Optional: SAML2 IdP SSO URL
SAML_CERTIFICATE=  # Optional: SAML2 IdP X.509 certificate (PEM)
SAML_ENTITY_ID=  # Optional: SAML2 Service Provider entity ID

# ─── Integration Credentials ──────────────────────────────────────
# ServiceNow
SERVICENOW_INSTANCE_URL=  # Optional: https://your-instance.service-now.com
SERVICENOW_USERNAME=  # Optional
SERVICENOW_PASSWORD=  # Optional

# GitHub
GITHUB_API_BASE=https://api.github.com
GITHUB_TOKEN=  # Optional: GitHub personal access token
GITHUB_WEBHOOK_SECRET=  # Optional: GitHub webhook secret

# GitLab
GITLAB_API_BASE=https://gitlab.com/api/v4
GITLAB_TOKEN=  # Optional: GitLab personal access token
GITLAB_WEBHOOK_SECRET=  # Optional: GitLab webhook secret

# Terraform Cloud
TERRAFORM_CLOUD_URL=https://app.terraform.io
TERRAFORM_CLOUD_TOKEN=  # Optional: Terraform Cloud API token
