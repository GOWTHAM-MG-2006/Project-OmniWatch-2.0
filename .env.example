# OmniWatch 2.0 — Environment Variables
# Copy this file to .env and fill in your values

# === Service URLs ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SSO_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
DASHBOARD_BACKEND_URL=http://localhost:8000/health
MINIO_HEALTH_URL=http://localhost:9002/minio/health/live
OPA_HEALTH_URL=http://localhost:8181/health
OLLAMA_HEALTH_URL=http://localhost:11434/api/tags

# === Database Connections ===
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
REDIS_HOST=localhost
REDIS_PORT=6379
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
OPA_URL=http://localhost:8181
OLLAMA_BASE_URL=http://localhost:11434
ARGOCD_URL=http://localhost:8080

# === Timeouts (seconds) ===
OPA_HTTP_TIMEOUT=5.0
SCANNER_TIMEOUT=5.0
SCANNER_SCAN_TIMEOUT=300.0
KAFKA_ADMIN_TIMEOUT=10.0
TERRAFORM_TIMEOUT=120.0
TERRAFORM_APPLY_TIMEOUT=300.0
ANSIBLE_TIMEOUT=120.0
ARGOCD_HTTP_TIMEOUT=30.0
KUBECTL_TIMEOUT=30.0
K8S_ACTION_TIMEOUT=60
DOCKER_TIMEOUT=5.0
HEALTH_CHECK_TIMEOUT=3.0
LOAD_TEST_HTTP_TIMEOUT=5.0
LLM_TIMEOUT=30.0
LLM_HTTP_TIMEOUT=60.0
TASK_FUTURE_TIMEOUT=30.0
SHUTDOWN_TIMEOUT=30.0

# === Redis Cache ===
L1_CACHE_MAX_SIZE=1024
L1_CACHE_TTL=60
L2_CACHE_TTL=120
REDIS_CONNECT_TIMEOUT=3.0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_HEALTH_TIMEOUT=2.0
REDIS_IDLE_TIMEOUT=300

# === ClickHouse ===
CH_IDLE_TIMEOUT=300
CH_SEND_RECEIVE_TIMEOUT=10

# === Kafka Tuning ===
KAFKA_BATCH_SIZE=16384
KAFKA_LINGER_MS=10
KAFKA_RETRIES=3
KAFKA_RETRY_BACKOFF_MS=100
KAFKA_BUFFER_MEMORY=33554432
KAFKA_MAX_IN_FLIGHT=5
KAFKA_MAX_POLL_RECORDS=500
KAFKA_SESSION_TIMEOUT=30000
KAFKA_HEARTBEAT_INTERVAL=10000
KAFKA_AUTO_COMMIT_INTERVAL=5000

# === TTL / Intervals ===
ENTITY_CACHE_TTL=300
ENTITY_REGISTRY_TTL=86400
ENTITY_RESOLUTION_TTL=604800
BASELINE_CACHE_TTL=3600
WATCHDOG_CHECK_INTERVAL=10.0
WATCHDOG_MAX_BACKOFF=60.0
WATCHDOG_CPU_BUDGET=1.0
WATCHDOG_MEMORY_LIMIT_MB=512
ASYNC_MAX_WORKERS=8
ASYNC_MAX_HISTORY=500
API_CACHE_TTL=30
DEFAULT_PAGE_SIZE=50

# === NQL ===
NQL_HOT_MAX_HOURS=1
NQL_WARM_MAX_DAYS=90
NQL_COLD_STORE_PATH=/tmp/omniwatch-cold

# === Topology ===
TOPOLOGY_QUERY_LIMIT=500
TOPOLOGY_EDGES_LIMIT=1000
TOPOLOGY_NEIGHBORS_LIMIT=50
TOPOLOGY_BLAST_RADIUS_LIMIT=100
GRAPH_QUERY_LIMIT=1000
BLAST_RADIUS_MAX_DEPTH=5
CAUSAL_MAX_DEPTH=5
GRANGER_MIN_P=0.05

# === AI/ML ===
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
ANOMALY_Z_THRESHOLD=3.0
EWMA_ALPHA=0.3
EWMA_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
BOCPD_THRESHOLD=0.95
MIN_ANOMALY_SCORE=0.25
LSTM_LOOKBACK=24
LSTM_EPOCHS=50
LSTM_HIDDEN_SIZE=32
LSTM_MIN_PER_STEP=5.0
FORECAST_MIN_PER_STEP=5.0

# === OTLP ===
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318

# === Federation ===
FEDERATION_HEALTH_TIMEOUT=10

# === Business/Cost ===
COST_PER_KWH=0.10
SERVICE_REVENUE_CONFIG={"payment-service": 150, "checkout-service": 120, "order-service": 100, "inventory-service": 50}
SERVICE_TXN_CONFIG={"payment-service": 500, "checkout-service": 300, "order-service": 200, "inventory-service": 100}

# === Policy ===
POLICY_SEVERITY_CUTOFF=P2
POLICY_CONFIDENCE_CUTOFF=0.7
POLICY_MAX_BLAST_RADIUS=5

# ─── Kafka Topics ──────────────────────────────────────────────────
KAFKA_TOPIC_TELEMETRY_RAW=omniwatch.telemetry.raw
KAFKA_TOPIC_METRICS_RAW=omniwatch.metrics.raw
KAFKA_TOPIC_LOGS_RAW=omniwatch.logs.raw
KAFKA_TOPIC_TRACES_RAW=omniwatch.traces.raw
KAFKA_TOPIC_TOPOLOGY_DELTAS=omniwatch.topology.deltas
KAFKA_TOPIC_ANOMALIES_DETECTED=omniwatch.anomalies.detected
KAFKA_TOPIC_INCIDENTS_CREATED=omniwatch.incidents.created
KAFKA_TOPIC_REMEDIATION_ACTIONS=omniwatch.remediation.actions
KAFKA_TOPIC_SECURITY_EVENTS=omniwatch.security.events
KAFKA_TOPIC_CONFIG_DRIFT=omniwatch.config.drift
KAFKA_TOPIC_SIMULATION_RESULTS=omniwatch.simulation.results

# ─── ClickHouse ─────────────────────────────────────────────────────
CLICKHOUSE_DATABASE=omniwatch

# ─── Redis ──────────────────────────────────────────────────────────
REDIS_DB=0

# ─── MinIO / Object Storage ────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_TELEMETRY=omniwatch-telemetry-archive
MINIO_BUCKET_INCIDENTS=omniwatch-incidents
MINIO_BUCKET_AUDIT=omniwatch-audit-logs
MINIO_BUCKET_MLDATA=omniwatch-ml-datasets
MINIO_BUCKET_RUNBOOKS=omniwatch-runbooks
MINIO_BUCKET_COMPLIANCE=omniwatch-compliance
MINIO_BUCKET_SIMULATIONS=omniwatch-simulations

# ─── Apache Kuzu (Graph Database) ──────────────────────────────────
KUZU_DATABASE_PATH=/data/omniwatch-graph

# ─── Dashboard Backend ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_ENV=development
DASHBOARD_LOG_LEVEL=info

# ─── Dashboard Frontend ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# ─── Security ──────────────────────────────────────────────────────
# Never commit real credentials. Use mock/simulate only.

# JWT RS256 Keys (REQUIRED)
# Generate with: python -c "from cryptography.hazmat.primitives.asymmetric import rsa; from cryptography.hazmat.primitives import serialization; key = rsa.generate_private_key(public_exponent=65537, key_size=2048); print('JWT_PRIVATE_KEY=' + key.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption()).decode()); print('JWT_PUBLIC_KEY=' + key.public_key().public_bytes(serialization.Encoding.PEM, serialization.PublicFormat.SubjectPublicKeyInfo).decode())"
JWT_PRIVATE_KEY=  # Required: RSA private key (PEM format)
JWT_PUBLIC_KEY=   # Required: RSA public key (PEM format)

# SSO Configuration (OIDC or SAML2 — at least one required)
# OIDC Configuration
OIDC_CLIENT_ID=  # Optional: OIDC client ID
OIDC_CLIENT_SECRET=  # Optional: OIDC client secret
OIDC_ISSUER=  # Optional: OIDC issuer URL

# SAML2 Configuration (fallback when OIDC not configured)
SAML_IDP_URL=  # Optional: SAML2 IdP SSO URL
SAML_CERTIFICATE=  # Optional: SAML2 IdP X.509 certificate (PEM)
SAML_ENTITY_ID=  # Optional: SAML2 Service Provider entity ID

# ─── Integration Credentials ──────────────────────────────────────
# ServiceNow
SERVICENOW_INSTANCE_URL=  # Optional: https://your-instance.service-now.com
SERVICENOW_USERNAME=  # Optional
SERVICENOW_PASSWORD=  # Optional

# GitHub
GITHUB_API_BASE=https://api.github.com
GITHUB_TOKEN=  # Optional: GitHub personal access token
GITHUB_WEBHOOK_SECRET=  # Optional: GitHub webhook secret

# GitLab
GITLAB_API_BASE=https://gitlab.com/api/v4
GITLAB_TOKEN=  # Optional: GitLab personal access token
GITLAB_WEBHOOK_SECRET=  # Optional: GitLab webhook secret

# Terraform Cloud
TERRAFORM_CLOUD_URL=https://app.terraform.io
TERRAFORM_CLOUD_TOKEN=  # Optional: Terraform Cloud API token
