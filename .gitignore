# ==========================================
# OmniWatch 2.0 - Git Ignore Rules
# ==========================================

# Environment files (NEVER commit)
.env
.env.*
!.env.example
!.env.template

# Keys and certificates (NEVER commit)
*.pem
*.key
*.p12
*.p12b
*.pfx
*.crt
*.cert
id_rsa*
id_ed25519*
jwt_private.pem
jwt_public.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Node.js
node_modules/
dist/
build/
.next/
.nuxt/
.cache/

# Docker
.docker/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Project-specific
Project-Details/
.mimocode/
docs/compose/
data/

# Sensitive files (NEVER commit)
Github_Token*.txt
*token*.txt
*secret*.txt

# MinIO data
minio-data/

# ClickHouse data
clickhouse-data/

# Redis data
redis-data/

# Kafka data
kafka-data/

# Ollama models
ollama-models/

# Kuzu database files
*.kuzu
kuzu-data/

# ML models (large files)
models/*.pt
models/*.onnx
models/*.pkl
*.pickle
